# Скопируйте в .env и подставьте токен бота из Discord Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=ваш_токен_здесь

# Опционально: ID сервера Discord — если указан, слэш-команды появятся на сервере сразу (иначе до 1 часа)
# Как узнать: Включи «Режим разработчика» в Настройки → Расширенные → правый клик по серверу → Копировать ID сервера
# DISCORD_GUILD_ID=123456789012345678

# --- Яндекс.Диск (команды /залить_ка, /залить_отчеты, /залить_присяга) ---
# Токен: см. раздел «Яндекс.Диск» в README (OAuth-токен приложения).
# YA_DISK_TOKEN=ваш_oauth_токен
# Папки на Диске для команд КА, отчеты, присяга (названия как в веб-интерфейсе):
# YA_FOLDER_1=КА
# YA_FOLDER_2=отчеты
# YA_FOLDER_3=присяга
